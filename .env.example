# --- Resend (catering form emails) — get key at https://resend.com ---
# Add the same keys in Vercel → Project → Settings → Environment Variables
RESEND_API_KEY=re_xxxx
# Where you receive enquiry emails (e.g. your business inbox)
ENQUIRY_TO_EMAIL=you@example.com
# After verifying a domain in Resend, e.g. Catering <catering@yourdomain.com>
# For testing, Resend allows: OlaJesu <onboarding@resend.dev> (only to your own account)
EMAIL_FROM=OlaJesu <onboarding@resend.dev>

# --- Optional: Cloudflare Turnstile (set site key in Vite, secret in Vercel only) ---
VITE_TURNSTILE_SITE_KEY=
# Server-side (do NOT use VITE_). Required if you show Turnstile in the form.
TURNSTILE_SECRET_KEY=
